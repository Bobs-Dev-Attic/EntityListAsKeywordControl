{
  "compilerOptions": {
    "target": "ES2015",
    "experimentalDecorators": true,
    "lib": [
      "es2015",
      "dom"
    ],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "out/controls",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "jsx": "react",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "strict": true,
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
